    {
      "parameters": {
        "jsCode": "const issues = $input.all();\nconst formattedIssues = [];\n\nfor (const item of issues) {\n  // Extract only the relevant fields from the GitHub JSON\n  const title = item.json.title || \"No Title\";\n  const body = item.json.body || \"No Description\";\n  const url = item.json.html_url || \"\";\n  const number = item.json.number || \"\";\n\n  // Combine the title and body into one clean text string for the embedding\n  const pageContent = `Issue #${number}: ${title}\\n\\n${body}`;\n\n  // Push to a new array, keeping the URL as metadata so you can link to it later\n  formattedIssues.push({\n    json: {\n      pageContent: pageContent.trim(),\n      metadata: {\n        source: url,\n        title: title,\n        issueNumber: number,\n        dataSource:\"github_issues\"\n      }\n    }\n  });\n}\n\n// Return the cleaned-up items\nreturn formattedIssues;"
      },
